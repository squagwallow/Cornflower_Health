# Cornflower Health — Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to the repository.
#
# SECURITY WARNING: The integration token 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
# that appeared in thread reports and project messages should be treated as COMPROMISED.
# Regenerate it immediately before use:
#   1. Go to https://www.notion.so/my-integrations
#   2. Find the Cornflower Health integration
#   3. Click "Show token" → "Regenerate"
#   4. Paste the new token below
#

# Notion integration secret token (starts with ntn_ or secret_)
NOTION_TOKEN=ntn_your_token_here

# ID of the Daily Health Metrics Notion database
# Current deployed database: 339d7cd8-531f-81f5-be5d-000bc78ce4eb
NOTION_DATABASE_ID=339d7cd8-531f-81f5-be5d-000bc78ce4eb

# Shared secret for validating incoming HAE webhook requests
# Set this in both HAE (webhook configuration) and the backend.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
HAE_WEBHOOK_SECRET=your_webhook_secret_here

# Port the backend webhook server listens on (default: 8000)
BACKEND_PORT=8000

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Set to true to run the backend in backfill mode (skips rows where date already exists in Notion)
BACKFILL_MODE=false
